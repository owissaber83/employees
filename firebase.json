{
  "database": {
    "rules": "database.rules.json"
  },
  "emulators": {
    "database": { "port": 9000 },
    "ui": { "enabled": false },
    "singleProjectMode": true
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "**/*.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/academy",
        "destination": "/academy.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}